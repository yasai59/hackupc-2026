{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Inkwell",
  "version": "0.1.0",
  "identifier": "com.inkwell.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:4321",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && cp -r sidecar/* src-tauri/resources/sidecar/"
  },
  "app": {
    "windows": [
      {
        "title": "Inkwell — Markdown Editor",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ws://localhost:*; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/sidecar/**/*"
    ]
  }
}